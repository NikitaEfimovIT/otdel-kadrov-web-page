# Скопируй в .env рядом и заполни. .env НЕ коммитить в git!
# Секреты сгенерируй так (каждый — своим запуском):
#   node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"

# --- Секреты Strapi 5 (все обязательны) ---
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=change_me
ADMIN_JWT_SECRET=change_me
TRANSFER_TOKEN_SALT=change_me
JWT_SECRET=change_me
ENCRYPTION_KEY=change_me

# --- База: локальный Postgres из docker-compose ---
DATABASE_CLIENT=postgres
DATABASE_NAME=otdelkadrov
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_SSL=false

# --- Апгрейд на Yandex Managed PostgreSQL (позже) ---
# DATABASE_HOST=<host>.mdb.yandexcloud.net
# DATABASE_PORT=6432
# DATABASE_SSL=true
# NODE_EXTRA_CA_CERTS=/opt/app/yc-root.crt   # CA-сертификат Yandex Cloud

# --- Прочее ---
HOST=0.0.0.0
PORT=1337
NODE_ENV=production

# Вебхук в Discord на новые заявки (из SETUP.md)
DISCORD_WEBHOOK_URL=
